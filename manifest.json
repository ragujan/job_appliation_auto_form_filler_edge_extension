{
  "manifest_version": 3,
  "name": "JobFill AI",
  "version": "1.0.0",
  "description": "Auto-fill job applications and tailor your resume using AI.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.greenhouse.io/*",
        "*://boards.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://jobs.lever.co/*",
        "*://*.myworkdayjobs.com/*",
        "*://*.workday.com/*",
        "*://*.ashbyhq.com/*",
        "*://*.smartrecruiters.com/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/*",
        "*://*.bamboohr.com/*",
        "*://*.jobvite.com/*",
        "*://*.icims.com/*",
        "*://*.taleo.net/*",
        "*://*.workable.com/*",
        "*://*.breezy.hr/*",
        "*://*.applytojob.com/*",
        "*://*.jazz.co/*",
        "*://*.recruitee.com/*",
        "*://*.teamtailor.com/*",
        "*://*.rippling.com/*",
        "*://*.ultipro.com/*",
        "*://*.paylocity.com/*"
      ],
      "js": ["src/applications.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "JobFill AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
