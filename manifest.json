{
  "manifest_version": 3,
  "name": "JobFill AI",
  "version": "1.0.0",
  "description": "Auto-fill job applications and tailor your resume using AI.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "JobFill AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
